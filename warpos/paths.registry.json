  "lintRules": {
    "_doc": "Mirror of WARN/CRITICAL regex arrays from scripts/path-lint.js. Migrated here so build.js can regenerate path-lint.rules.generated.json. Lint rules are generated artifact; edit registry not script.",
    "critical": [
      {
        "match": "\\.claude\\/events\\/[^/\\s\"'`)\\]]",
        "suggestion": ".claude/project/events/ (or paths.events)",
        "why": "path moved under .claude/project/ in v2 layout"
      },
      {
        "match": "\\.claude\\/memory\\/[^/\\s\"'`)\\]]",
        "suggestion": ".claude/project/memory/ (or paths.memory)",
        "why": "path moved under .claude/project/ in v2 layout"
      },
      {
        "match": "\\.claude\\/maps\\/[^/\\s\"'`)\\]]",
        "suggestion": ".claude/project/maps/ (or paths.maps)",
        "why": "path moved under .claude/project/ in v2 layout"
      },
      {
        "match": "\\.claude\\/handoffs\\/",
        "suggestion": ".claude/runtime/handoffs/ (or paths.handoffs)",
        "why": "handoffs moved under .claude/runtime/"
      },
      {
        "match": "\\.claude\\/logs\\/",
        "suggestion": ".claude/runtime/logs/ (or paths.logs)",
        "why": "logs moved under .claude/runtime/"
      },
      {
        "match": "\\.claude\\/plans\\/",
        "suggestion": ".claude/runtime/plans/ (or paths.plans)",
        "why": "plans moved under .claude/runtime/"
      },
      {
        "match": "context-enhancer\\.js",
        "suggestion": "smart-context.js",
        "why": "renamed"
      },
      {
        "match": "prompt-enhancer\\.js",
        "suggestion": "smart-context.js",
        "why": "merged into smart-context.js"
      },
      {
        "match": "\\.claude\\/agents\\/\\.system\\/oneshot\\/store\\.json",
        "suggestion": ".claude/agents/store.json (or paths.store)",
        "why": "wrong path — no .system/oneshot/ dir"
      },
      {
        "match": "\\bbeta-persona\\.md\\b",
        "suggestion": "judgement-model.md (or paths.judgmentModel)",
        "why": "renamed during privacy pass"
      },
      {
        "match": "\\.beta-mining-recommendations\\.md",
        "suggestion": "judgement-model-recommendations.md",
        "why": "renamed during privacy pass"
      },
      {
        "match": "docs\\/05-features\\/",
        "suggestion": "requirements/05-features/ (or paths.specsRoot)",
        "why": "Phase 1 final-A: docs/05-features → requirements/05-features"
      },
      {
        "match": "docs\\/03-requirement-standards\\/",
        "suggestion": "requirements/_standards/ (or paths.requirementsRoot)",
        "why": "Phase 1 final-A: docs/03-requirement-standards → requirements/_standards"
      }
    ],
    "_critical_doc": "Above are paths that resolve to NOTHING in the current layout (or to-be-current after Phase 1 final-A). Lint exits 1 on any hit.",
    "warnKeys": [
      "eventsFile",
      "toolsFile",
      "requirementsFile",
      "requirementsStagedFile",
      "decisionLedger",
      "providerTrace",
      "learningsFile",
      "tracesFile",
      "systemsFile",
      "recurringIssuesFile",
      "judgmentModel",
      "judgmentRecommendations",
      "betaEvents",
      "betaSourceData",
      "lexicon",
      "pathsLib",
      "loggerLib",
      "handoffLatest",
      "store",
      "specGraph",
      "manifest",
      "settings"
    ],
    "_warnKeys_doc": "These keys point at single files. Hardcoded literal use should warn (paths.X is preferred). build.js generates regex arrays from the registry path values."
  },
  "skipSubstrings": [
    ".claude/runtime/",
    ".claude/project/events/",
    ".claude/project/decisions/",
    ".claude/project/memory/",
    ".claude/project/maps/",
