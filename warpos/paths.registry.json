    "scripts/path-lint.js",
    "scripts/hooks/path-guard.js",
    "/check/references.md",
    ".claude/dreams/",
    ".claude/agents/02-oneshot/.system/retros/",
    ".claude/agents/.system/dispatch-backups/",
    "backups/",
    "SYSTEMS-REFERENCE.md",
    "warpos-system-updates",
    "warpos-roadmap.md",
    "ROADMAP.md",
    "warpos/paths.registry.json",
    "scripts/path-lint.rules.generated.json",
    "scripts/hooks/lib/paths.generated.js"
  ],
  "_skipSubstrings_doc": "File substrings excluded from path-lint scan. Mostly archives, runtime, the linter itself, and (post-1B) the generated artifacts.",
  "skipDirs": [
    "node_modules",
    ".git",
    ".next",
