{
  "$schema": "warpos/paths-registry/v1",
  "version": 4,
  "_doc": "Path identity registry. Source of truth for project-relative paths. Consumed by scripts/paths/build.js, which derives: (1) .claude/paths.json (flat key→string used by hooks at runtime), (2) scripts/hooks/lib/paths.generated.js (fallback when paths.json missing), (3) scripts/path-lint.rules.generated.json (regex arrays for path-lint critical+warn), (4) schemas/paths.schema.json (validator), (5) docs/04-architecture/PATH_KEYS.md (human reference). To rename a path: edit here, run scripts/paths/build.js, commit all generated artifacts together.",
  "_field_meaning": {
    "path": "Project-relative path from repo root, forward slashes",
    "kind": "dir | file | jsonl | json | md | js — drives schema validators + lint rules",
    "owner": "framework (shipped by WarpOS) | generated (built by tooling) | runtime (session-written state) | project (user/team-owned content)",
    "mutable": "true if files inside are written during normal operation; affects release scrubbing + retention policy",
    "aliases": "alternative spellings/keys still accepted at the consumer boundary (warn-on-use)",
    "deprecatedAliases": "old keys/paths whose use is hard-blocked by path-guard",
    "introducedIn": "WarpOS version when this key first existed",
    "removedIn": "WarpOS version when this key was removed; null if still active",
    "replaces": "previous key name if this entry was renamed",
    "docsToken": "the token used in markdown prose (e.g. paths.eventsFile)"
  },
